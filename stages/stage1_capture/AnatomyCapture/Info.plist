<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundleDisplayName</key>
	<string>AnatomyCapture</string>
	<key>CFBundlePackageType</key>
	<string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>

	<!-- Camera access is required; ARKit crashes on session start without this. -->
	<key>NSCameraUsageDescription</key>
	<string>AnatomyCapture uses the rear camera and LiDAR sensor to record a metric 3D scan of the region of interest for clinical documentation.</string>

	<!-- Gate install to LiDAR / ARKit-capable devices. -->
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>arkit</string>
	</array>

	<!-- Portrait + both landscapes. Saved color/depth buffers and intrinsics are ALWAYS
	     written in the sensor-native (un-rotated) frame regardless of interface orientation
	     (IOS_NOTES.md §6): the capture code reads frame.camera.intrinsics / the AVCameraCalibration
	     matrix directly and never rotates the data-output connection or bakes displayTransform in,
	     so the UI can rotate freely while the data stays orientation-agnostic. Run the §7
	     orientation self-test on-device once to confirm no orientation-dependent API slipped in. -->
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>

	<!-- Expose the session folder in the Files app (On My iPhone → AnatomyCapture)
	     so captures can be copied to the pipeline; both keys are needed. -->
	<key>UIFileSharingEnabled</key>
	<true/>
	<key>LSSupportsOpeningDocumentsInPlace</key>
	<true/>

	<!-- Transmit goes to the pipeline box by raw IP over plain HTTP (http://184.105.3.239:8902).
	     iOS ATS blocks cleartext HTTP by default, and NSExceptionDomains does not apply to IP
	     literals — so a global allowance is the only working exception for an IP endpoint. The
	     upload itself is bearer-token + per-transmit-PIN gated server-side; the proper long-term
	     fix is TLS via a reverse proxy + domain (scripts/upload_server/DEPLOY.md), then remove this. -->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsArbitraryLoads</key>
		<true/>
	</dict>

	<key>UILaunchScreen</key>
	<dict/>
</dict>
</plist>
